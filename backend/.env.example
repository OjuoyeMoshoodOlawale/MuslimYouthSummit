# =============================================================
# MYS Platform — Environment Variables
# Copy this file to .env and fill in your values.
#
# REQUIRED (app will not start without these):
#   DB_HOST, DB_NAME, DB_USER, JWT_SECRET
#
# OPTIONAL (app starts fine, features disabled until set):
#   DB_PASS, PAYSTACK_*, SMTP_*, TERMII_*
# =============================================================

# ── Database (REQUIRED) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mys_platform

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── JWT (REQUIRED) ────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_characters
JWT_EXPIRES_IN=8h

# ── Paystack (OPTIONAL — needed for online payments) ──────────
# Get keys from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook secret: Paystack dashboard → Settings → API Keys & Webhooks
PAYSTACK_WEBHOOK_SECRET=
# Where Paystack redirects after payment (must be your frontend URL)
PAYMENT_CALLBACK_URL=http://localhost:5173/ticket/verify

# ── Email / SMTP (OPTIONAL — needed to send emails) ──────────
# Gmail: enable 2FA → create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_character_app_password
EMAIL_FROM=Muslim Youth Summit <noreply@muslimyouthsummit.com>

# ── Termii SMS (OPTIONAL — needed to send SMS) ────────────────
# Sign up at: https://app.termii.com
# Sender ID: max 11 chars, must be pre-approved by Termii
TERMII_API_KEY=
TERMII_SENDER_ID=MYSummit
# Channel: generic (default) | dnd (bypasses DND) | whatsapp
TERMII_CHANNEL=generic
