# =============================================================
# MYS Platform — Backend Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password
DB_NAME=mys_platform

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=change_this_to_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# Paystack (Nigerian payment) — https://dashboard.paystack.com
PAYSTACK_SECRET_KEY=sk_test_xxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxx

# SMTP Email (Gmail example — use App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Muslim Youth Summit <noreply@muslimyouthsummit.com>

# Termii SMS (Nigeria) — https://app.termii.com
# Leave blank to disable SMS (system still works without it)
TERMII_API_KEY=
TERMII_SENDER_ID=MYSummit
TERMII_CHANNEL=generic
